    // Inicializar la tabla de horarios visuales (Filas por hora de 7 a 22)
    function initScheduleTable() {
        const body = document.getElementById('scheduleBody');
        body.innerHTML = '';
        const dias = ['Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
        
        for (let h = 7; h <= 21; h++) {
            const tr = document.createElement('tr');
            
            // Columna de etiqueta horaria am/pm
            const tdHora = document.createElement('td');
            tdHora.className = 'time-col';
            let displayHour = h > 12 ? (h - 12) + ':00 pm' : (h === 12 ? '12:00 pm' : h + ':00 am');
            let nextHour = (h + 1) > 12 ? ((h + 1) - 12) + ':00 pm' : ((h + 1) === 12 ? '12:00 pm' : (h + 1) + ':00 am');
            tdHora.innerText = `${displayHour} - ${nextHour}`;
            tr.appendChild(tdHora);
            
            // Columnas para los días de la semana
            dias.forEach(dia => {
                const td = document.createElement('td');
                td.id = `cell-${dia}-${h}`;
                tr.appendChild(td);
            });
            
            body.appendChild(tr);
        }
    }

    // Mostrar el calendario del profesor seleccionado
    function displayTeacherSchedule(nombreDocente) {
        // Limpiar bloques anteriores
        document.querySelectorAll('#scheduleBody td:not(.time-col)').forEach(td => {
            td.className = '';
            td.innerText = '';
        });

        const info = docentesDB[nombreDocente];
        const titleDiv = document.getElementById('selectedTeacherName');
        const noteDiv = document.getElementById('sharedNote');

        if (!info) {
            titleDiv.innerText = "Docente no encontrado";
            noteDiv.style.display = 'none';
            return;
        }

        titleDiv.innerText = `Horario Ocupado: ${nombreDocente}`;

        // Alerta dinámica en rojo si comparte curso
        if (info.compartido && info.companeros.length > 0) {
            noteDiv.innerText = `⚠️ Este docente comparte curso con: ${info.companeros.join(', ')}`;
            noteDiv.style.display = 'block';
        } else {
            noteDiv.style.display = 'none';
        }

        // Marcar en azul los bloques correspondientes
        info.horarios.forEach(bloque => {
            for (let h = bloque.start; h < bloque.end; h++) {
                const cell = document.getElementById(`cell-${bloque.dia}-${h}`);
                if (cell) {
                    cell.className = 'occupied';
                    cell.innerText = 'DICTANDO CLASE (OCUPADO)';
                }
            }
        });
    }

    // Configuración del input buscador con autocompletado inteligente
    const searchInput = document.getElementById('searchTeacher');
    const suggestionsDiv = document.getElementById('suggestions');

    searchInput.addEventListener('input', function() {
        const query = this.value.toUpperCase().trim();
        suggestionsDiv.innerHTML = '';
        
        if (!query) {
            suggestionsDiv.style.display = 'none';
            return;
        }

        // Filtro reactivo mientras se escribe
        const matches = Object.keys(docentesDB).filter(nombre => nombre.includes(query));

        if (matches.length > 0) {
            // Mostrar hasta 6 coincidencias simultáneas
            matches.slice(0, 6).forEach(match => {
                const div = document.createElement('div');
                div.innerText = match;
                div.addEventListener('click', () => {
                    searchInput.value = match;
                    suggestionsDiv.style.display = 'none';
                    displayTeacherSchedule(match);
                });
                suggestionsDiv.appendChild(div);
            });
            suggestionsDiv.style.display = 'block';
        } else {
            suggestionsDiv.style.display = 'none';
        }
    });

    // Cerrar el menú de sugerencias si se hace clic afuera
    document.addEventListener('click', function(e) {
        if (e.target !== searchInput) {
            suggestionsDiv.style.display = 'none';
        }
    });

    // Iniciar interfaz
    initScheduleTable();
</script>
